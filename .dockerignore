# Version control
.git
.gitignore

# Python
__pycache__
*.py[cod]
*$py.class
*.so
.venv
venv
env

# IDE
.idea
.vscode
*.swp
*.swo

# macOS
.DS_Store
__MACOSX

# Documentation and audit files (not needed in runtime)
docs/
*.md
!README.md

# Tests and load tests (not needed in production)
tests/
load_tests/
pytest.ini

# Translation patches (applied at build time, not runtime)
translation_patch_*.json
translation_tasks.json
apply_*_patch.py

# Scripts (dev/migration tools, mostly not needed at runtime)
scripts/
# Exceptions: scripts launched from the admin dashboard must be in the image.
!scripts/migrate_samopis_to_remnawave.py
!scripts/verify_samopis_migration.py
# Incy deep-link sidecar — invoked by app/services/incy_crypto.py at runtime
# every time a user opens the iOS «🌐 Incy» button. Without this file in the
# image, incy_crypto._SCRIPT_PATH.is_file() returns False on startup, the
# kill-switch flips, and the Incy button never appears in the UI.
!scripts/incy_encode.mjs

# Audit reports
*_AUDIT.md
*_PLAN.md

# Dashboard build artifacts — built INSIDE the Dockerfile (stage 1),
# not copied from the host. Always exclude the host's local
# node_modules/dist; they would slow the build and waste image space.
dashboard/node_modules
dashboard/dist
