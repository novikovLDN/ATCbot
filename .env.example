# Payment Integration (Railway + Cloudflare)
# Copy to .env and fill values. Use PROD_/STAGE_/LOCAL_ prefix per APP_ENV.

# Required: stage | prod | local
APP_ENV=stage

# === Required ===
STAGE_BOT_TOKEN=
STAGE_DATABASE_URL=postgresql://user:pass@host:5432/dbname
STAGE_ADMIN_TELEGRAM_ID=
PROD_BOT_TOKEN=
PROD_DATABASE_URL=postgresql://user:pass@host:5432/dbname
PROD_ADMIN_TELEGRAM_ID=

# === SBP payments (Platega.io) ===
STAGE_PLATEGA_MERCHANT_ID=aa5f5d2d-162e-4dad-a58d-c6dedd89360f
STAGE_PLATEGA_SECRET=
PROD_PLATEGA_MERCHANT_ID=aa5f5d2d-162e-4dad-a58d-c6dedd89360f
PROD_PLATEGA_SECRET=

# Public base URL for payment webhooks (must be reachable by payment providers)
PUBLIC_BASE_URL=https://atcbot-production-2f93.up.railway.app

# === VPN API (Cloudflare Tunnel / public HTTPS) ===
# Bot only needs URL and API key. API server owns port, SNI, public key, etc.
# MUST be HTTPS public domain (api.mynewllcw.com). No private IP.
STAGE_XRAY_API_URL=https://api.mynewllcw.com
STAGE_XRAY_API_KEY=
PROD_XRAY_API_URL=https://api.mynewllcw.com
PROD_XRAY_API_KEY=

# Plus tariff: public URL of VPN server for subscription link (GET /sub/{uuid} returns Base64).
# Used for "Подключиться" inline button (Telegram accepts only https://).
STAGE_VPN_SERVER_URL=https://api.mynewllcw.com
PROD_VPN_SERVER_URL=https://api.mynewllcw.com

# === Card payments (optional) ===
STAGE_TG_PROVIDER_TOKEN=
PROD_TG_PROVIDER_TOKEN=

# === Webhook (Railway deployment) ===
STAGE_WEBHOOK_URL=https://atcbot-production-2f93.up.railway.app/telegram/webhook
STAGE_WEBHOOK_SECRET=your-stage-secret-here
PROD_WEBHOOK_URL=https://atcbot-production-2f93.up.railway.app/telegram/webhook
PROD_WEBHOOK_SECRET=generate-with-python3-secrets-token-hex-32
# PORT is injected by Railway automatically — do not set manually

# === Redis (FSM storage + rate limiting) ===
# Provides persistent FSM states (survive restarts) and Redis-backed rate limiting.
# If not set, falls back to in-memory storage (states lost on restart, rate limits per-instance only).
# Railway: add Redis plugin → use the internal URL (redis://default:pass@redis.railway.internal:6379)
STAGE_REDIS_URL=redis://default:password@redis.railway.internal:6379
PROD_REDIS_URL=redis://default:password@redis.railway.internal:6379

# === CryptoBot (Crypto Pay, optional) ===
STAGE_CRYPTOBOT_API_TOKEN=
PROD_CRYPTOBOT_API_TOKEN=

# === Mini App URL (optional, defaults to production Railway URL) ===
STAGE_MINI_APP_URL=https://atlas-miniapp-production.up.railway.app
PROD_MINI_APP_URL=https://atlas-miniapp-production.up.railway.app

# === Mini App deep-link settings (for Инструкция button) ===
STAGE_BOT_USERNAME=atlassecure_bot
PROD_BOT_USERNAME=atlassecure_bot
STAGE_MINI_APP_NAME=app
PROD_MINI_APP_NAME=app
