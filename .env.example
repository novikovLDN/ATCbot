# Payment Integration (Railway + Cloudflare)
# Copy to .env and fill values. Use PROD_/STAGE_/LOCAL_ prefix per APP_ENV.

# Required: stage | prod | local
APP_ENV=stage

# === Required ===
STAGE_BOT_TOKEN=
STAGE_DATABASE_URL=postgresql://user:pass@host:5432/dbname
STAGE_ADMIN_TELEGRAM_ID=
PROD_BOT_TOKEN=
PROD_DATABASE_URL=postgresql://user:pass@host:5432/dbname
PROD_ADMIN_TELEGRAM_ID=

# === SBP payments (Platega.io) ===
STAGE_PLATEGA_MERCHANT_ID=aa5f5d2d-162e-4dad-a58d-c6dedd89360f
STAGE_PLATEGA_SECRET=
PROD_PLATEGA_MERCHANT_ID=aa5f5d2d-162e-4dad-a58d-c6dedd89360f
PROD_PLATEGA_SECRET=

# Public base URL for payment webhooks (must be reachable by payment providers)
PUBLIC_BASE_URL=https://atcbot-production-2f93.up.railway.app

# === VPN API (Cloudflare Tunnel / public HTTPS) ===
# Bot only needs URL and API key. API server owns port, SNI, public key, etc.
# MUST be HTTPS public domain (api.mynewllcw.com). No private IP.
STAGE_XRAY_API_URL=https://api.mynewllcw.com
STAGE_XRAY_API_KEY=
PROD_XRAY_API_URL=https://api.mynewllcw.com
PROD_XRAY_API_KEY=

# Plus tariff: public URL of VPN server for subscription link (GET /sub/{uuid} returns Base64).
# Used for "Подключиться" inline button (Telegram accepts only https://).
STAGE_VPN_SERVER_URL=https://api.mynewllcw.com
PROD_VPN_SERVER_URL=https://api.mynewllcw.com

# === Card payments (optional) ===
STAGE_TG_PROVIDER_TOKEN=
PROD_TG_PROVIDER_TOKEN=

# === Webhook (Railway deployment) ===
STAGE_WEBHOOK_URL=https://atcbot-production-2f93.up.railway.app/telegram/webhook
STAGE_WEBHOOK_SECRET=your-stage-secret-here
PROD_WEBHOOK_URL=https://atcbot-production-2f93.up.railway.app/telegram/webhook
PROD_WEBHOOK_SECRET=generate-with-python3-secrets-token-hex-32
# PORT is injected by Railway automatically — do not set manually

# === Redis (FSM storage + rate limiting) ===
# Provides persistent FSM states (survive restarts) and Redis-backed rate limiting.
# If not set, falls back to in-memory storage (states lost on restart, rate limits per-instance only).
# Railway: add Redis plugin → use the internal URL (redis://default:pass@redis.railway.internal:6379)
STAGE_REDIS_URL=redis://default:password@redis.railway.internal:6379
PROD_REDIS_URL=redis://default:password@redis.railway.internal:6379

# === CryptoBot (Crypto Pay, optional) ===
STAGE_CRYPTOBOT_API_TOKEN=
PROD_CRYPTOBOT_API_TOKEN=

# === Mini App URL (optional, defaults to production Railway URL) ===
STAGE_MINI_APP_URL=https://atlas-miniapp-production.up.railway.app
PROD_MINI_APP_URL=https://atlas-miniapp-production.up.railway.app

# === Mini App deep-link settings (for Инструкция button) ===
STAGE_BOT_USERNAME=atlassecure_bot
PROD_BOT_USERNAME=atlassecure_bot
STAGE_MINI_APP_NAME=app
PROD_MINI_APP_NAME=app

# === Remnawave panel (bypass tier — already in use) ===
STAGE_REMNAWAVE_API_URL=
STAGE_REMNAWAVE_API_TOKEN=
STAGE_REMNAWAVE_SQUAD_UUID=
STAGE_REMNAWAVE_SUB_BASE_URL=https://rmnw.atlassecure.ru/api/sub
PROD_REMNAWAVE_API_URL=
PROD_REMNAWAVE_API_TOKEN=
PROD_REMNAWAVE_SQUAD_UUID=
PROD_REMNAWAVE_SUB_BASE_URL=https://rmnw.atlassecure.ru/api/sub

# === Remnawave panel (premium tier — migration 045) ===
# MainServer squad UUID — created in the Remnawave panel, "MainServer" squad.
# Required for the samopis→Remnawave migration script and the new purchase flow.
STAGE_REMNAWAVE_MAIN_SQUAD_UUID=
PROD_REMNAWAVE_MAIN_SQUAD_UUID=
# Try to keep legacy samopis UUIDs as the Remnawave entity uuid (true/false).
# Set to false if the panel rejects forced uuids on creation.
STAGE_REMNAWAVE_PREMIUM_FORCE_UUID=true
PROD_REMNAWAVE_PREMIUM_FORCE_UUID=true
# Username template — must produce ≤32 chars; {telegram_id} is mandatory.
STAGE_REMNAWAVE_PREMIUM_USERNAME_PATTERN=tg_{telegram_id}_premium
PROD_REMNAWAVE_PREMIUM_USERNAME_PATTERN=tg_{telegram_id}_premium
STAGE_REMNAWAVE_PREMIUM_DEVICE_LIMIT=5
PROD_REMNAWAVE_PREMIUM_DEVICE_LIMIT=5

# Task 6: External Squad UUID for premium users — when set, the bot
# stamps every premium entity with this `externalSquadUuid` so Remnawave
# overrides their subscription Template to "Unlimited" (RU split-routing
# + SDK/SMTP/mining blocklists).  Bypass entities are NOT assigned this
# field.  Leave empty to disable the feature (no field is sent).
STAGE_REMNAWAVE_PREMIUM_EXTERNAL_SQUAD_UUID=894f4c66-a725-4a24-b0ba-f6ca2b6b5a79
PROD_REMNAWAVE_PREMIUM_EXTERNAL_SQUAD_UUID=894f4c66-a725-4a24-b0ba-f6ca2b6b5a79

# === Task 2 cut-over: bot uses Remnawave for ALL purchases (no samopis) ===
# Default TRUE — samopis is decommissioned.  Flip to false ONLY for
# emergency rollback if samopis xray master needs to be reinstated.
STAGE_PURCHASE_FLOW_REMNAWAVE=true
PROD_PURCHASE_FLOW_REMNAWAVE=true
# Trial bypass allowance (premium duration is fixed at 3 days by trial logic)
STAGE_TRIAL_BYPASS_GB=1
PROD_TRIAL_BYPASS_GB=1
# Bypass entity username pattern. Default `{telegram_id}` matches the
# existing ~2500 entities in the panel — change to `tg_{telegram_id}_bypass`
# only on a fresh deployment.
STAGE_REMNAWAVE_BYPASS_USERNAME_PATTERN={telegram_id}
PROD_REMNAWAVE_BYPASS_USERNAME_PATTERN={telegram_id}
STAGE_REMNAWAVE_BYPASS_DEVICE_LIMIT=5
PROD_REMNAWAVE_BYPASS_DEVICE_LIMIT=5
# Optional aliases for the TZ's naming convention; either name is honoured.
# STAGE_REMNAWAVE_TOKEN=
# STAGE_REMNAWAVE_CLIENTS_SQUAD_UUID=

# === Subscription URL fallback (legacy samopis → Remnawave proxy) ===
# Master switch for app/api/subscription_proxy.py.  Default off; flip on per
# environment once sub.atlassecure.ru is pointed at this bot.
STAGE_SUBSCRIPTION_PROXY_ENABLED=false
PROD_SUBSCRIPTION_PROXY_ENABLED=false
# Base URL of the legacy samopis sub endpoint, used as a fallback target for
# unmigrated users during the grace period (e.g. https://api.mynewllcw.com).
STAGE_LEGACY_SAMOPIS_SUB_BASE_URL=
PROD_LEGACY_SAMOPIS_SUB_BASE_URL=
